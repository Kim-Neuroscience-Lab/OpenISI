# Build artifacts
target/
*.exe
*.dll
*.pdb

# Vendored third-party artifacts
vendor/

# Dev debugging output (generated figures)
dev_figures/

# Data files
*.oisi
*.h5
*.hdf5
*.mat

# Image files (data output, not source assets)
*.png
!src-tauri/icons/*.png
!src-tauri/icons/*.ico

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Tauri build artifacts
src-tauri/WixTools/
src-tauri/gen/

# Godot editor artifacts (legacy, not part of 1.0)
.godot/
*.import

# Legacy directories (not part of Rust rewrite)
/bin/
/build/
/daemon/
/dist/
/extension/

# Runtime data
data/
*.log

# Local config overrides
settings.local.json

# Test data
test_data/

# Claude artifacts
.claude/

# External reference codebases (MATLAB/Python pipelines we port from) — not tracked
/reference/

# Editor/backup scratch files (never commit)
*.bak
*.orig

# Python bytecode (golden-fixture generators are run, not byte-compiled into VCS)
__pycache__/
*.pyc

# Transient persisted session state (resumability) — per-machine runtime, not source
config/dev/session.json
